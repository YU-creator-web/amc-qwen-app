# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# デプロイ名
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-1.5
AZURE_OPENAI_EXTRACT_DEPLOYMENT=gpt-5.4

# API Keys（同一リソースなら同じキーでOK）
REALTIME_KEY=your-api-key
CHAT_KEY=your-api-key

# App
DB_PATH=anmokuchi.db
UPLOAD_DIR=uploads
